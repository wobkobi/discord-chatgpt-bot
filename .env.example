# Copy this file to .env and fill in your values


# Discord

# https://discord.com/developers/applications
BOT_TOKEN=
# Same page as the bot token
CLIENT_ID=
# Your Discord user ID; controls who can run owner-only commands
OWNER_ID=


# OpenAI

# https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Do not change after first run; all saved data will become unreadable
ENCRYPTION_KEY=


# Model

# Set to true to use a fine-tuned model instead of gpt-4o
USE_FINE_TUNED_MODEL=false
# Required when USE_FINE_TUNED_MODEL=true
FINE_TUNED_MODEL_NAME=
# Set to true if the fine-tuned model supports image input
FINE_TUNED_SUPPORTS_VISION=false


# Persona

# Injects persona from src/config/persona.json into every prompt
USE_PERSONA=false
# Set to false if your fine-tuned model already knows Discord markdown
USE_MARKDOWN_GUIDE=true


# GIFs

# https://developers.google.com/tenor/guides/quickstart
TENOR_API_KEY=
# App identifier sent to Tenor; any short string works
TENOR_CLIENT_KEY=discord-bot
# https://developers.giphy.com
GIPHY_API_KEY=


# Memory

# Max long-term memory entries per prompt (higher = more tokens)
MAX_MEMORY_ENTRIES=50


# Logging

# Options: error, warn, info, debug
LOG_LEVEL=info
