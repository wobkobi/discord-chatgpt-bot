{
  "name": "chatgpt",
  "version": "2.1.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "build/index.js",
  "scripts": {
    "build": "tsc && tsc-alias",
    "build:changelog": "npx @discordx/changelog --src src",
    "dev": "nodemon --watch src --ext ts --exec \"tsx src/index.ts\"",
    "start": "npm run build && node build/index.js",
    "watch": "nodemon --exec npm run dev --watch src --ext ts",
    "lint": "eslint \"src/**/*.{js,ts}\" --fix",
    "format": "prettier --write \"**/*.{js,ts,mjs,json,yml,yaml,md}\""
  },
  "dependencies": {
    "@discordjs/rest": "^2.6.1",
    "@giphy/js-fetch-api": "^5.7.0",
    "discord-api-types": "^0.38.47",
    "discord.js": "^14.26.3",
    "dotenv": "^17.4.2",
    "logform": "^2.7.0",
    "luxon": "^3.7.2",
    "mathjax-full": "^3.2.2",
    "node-fetch": "^3.3.2",
    "openai": "^6.34.0",
    "sanitize-html": "^2.17.3",
    "sharp": "^0.34.5",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.6.0",
    "@types/sanitize-html": "^2.16.1",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": "22.x",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "undici": "^7.18.2"
  },
  "lint-staged": {
    "**/*.{js,ts}": [
      "prettier --write",
      "eslint --fix"
    ],
    "**/*.{json,yml,yaml,md,mjs}": "prettier --write"
  }
}
